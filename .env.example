APP_NAME=FieldSyncAI
APP_ENV=development
DEBUG=true

API_PREFIX=/api/v1

# Comma-separated list of allowed origins for browser-based clients
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Authentication
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ISSUER=fieldsyncai
JWT_AUDIENCE=fieldsyncai-users

# Local LLM and embeddings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

HF_TOKEN=replace-with-your-huggingface-token
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Vector database
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=fieldsyncai_docs

# Storage and caching
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=sqlite:///./fieldsyncai.db

# Retrieval settings
VECTOR_TOP_K=5
CHUNK_SIZE=800
CHUNK_OVERLAP=100